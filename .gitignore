# SOLO CORN SKILLS - .gitignore

# Core framework files to exclude
.trae/

# ========================================
# Node.js / JavaScript / TypeScript
# ========================================
node_modules/
dist/
build/
out/
*.tsbuildinfo
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ========================================
# TypeScript / Compiled Output
# ========================================
*.js
!*.d.ts
*.js.map
*.d.ts.map

# ========================================
# Operating System Files
# ========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ========================================
# Editor & IDE Files
# ========================================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/*.code-snippets

# IntelliJ / IDEA
.idea/
*.iws
*.iml
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/
*.swp

# Vim / Neovim
*.vim
*.swp
*.swo
*~
.nvim

# ========================================
# Build & Compilation
# ========================================
# Tools/cli build
tools/cli/dist/
tools/cli/*.d.ts
tools/cli/*.js
tools/cli/*.js.map

# Examples build
examples/*/node_modules/
examples/*/dist/
examples/*/build/

# ========================================
# Package Manager Files
# ========================================
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm
.yarn-integrity

# ========================================
# Temporary & Cache Files
# ========================================
tmp/
temp/
*.tmp
*.temp
.cache/
.eslintcache
.parcel-cache
.next
.nuxt
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.tern-port

# ========================================
# Environment & Configuration
# ========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.secrets
*.env.example
*.env.template

# ========================================
# Testing & Coverage
# ========================================
coverage/
.nyc_output/
*.lcov
.puppeteerrc

# ========================================
# Project-Specific
# ========================================
# Output files generated by examples
examples/*/*.json
examples/*/*.md
examples/*/output/
examples/*/results/

# Local project config
*.local.json
*.local.yml
*.local.yaml
*.local.toml
*.local.conf

# ========================================
# Other
# ========================================
# Archive files
*.zip
*.tar.gz
*.rar
*.7z

# Logs
logs/
*.log

# Backup files
*.bak
*.backup
*.old
